---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import WritingCard from "../components/WritingCard.astro";

const work = (await getCollection("work")).sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);
const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const writing = (await getCollection("writing"))
  .filter((article) => article.data.featured)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 2);
const continuum = work.find((project) => project.id === "continuum")!;
const supportingWork = work.filter((project) => project.id !== "continuum");
---

<BaseLayout>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Software engineer &amp; product builder</p>
        <h1>I turn ambiguous ideas into <em>polished</em> digital products.</h1>
        <p class="hero-lede">
          I work across product thinking, engineering, design systems, and launch execution to turn rough ideas into useful, thoughtful software.
        </p>
        <div class="button-row">
          <a class="button button--primary" href="/work/">View selected work <span aria-hidden="true">↗</span></a>
          <a class="button button--secondary" href="/start/">Discuss a product</a>
        </div>
        <p class="availability-note">Open to thoughtful conversations and selected collaborations.</p>
      </div>

      <div class="systems-card" aria-label="A product moves from a clear model, through engineering, into a launch-ready system">
        <div class="systems-card-header">
          <span>Complete product loop</span>
          <span>01—03</span>
        </div>
        <div class="system-stack">
          <div class="system-layer">
            <span>Clarify</span>
            <strong>Make the real problem legible.</strong>
          </div>
          <div class="system-layer">
            <span>Build</span>
            <strong>Turn the critical path into software.</strong>
          </div>
          <div class="system-layer">
            <span>Ship</span>
            <strong>Connect product, presentation, and launch.</strong>
          </div>
        </div>
        <div class="system-output">idea → system → product <b>ready</b></div>
      </div>
    </div>
  </section>

  <div class="capability-band" aria-label="Areas of work">
    <div class="shell capability-list">
      <span>Product strategy</span><i>·</i>
      <span>Engineering</span><i>·</i>
      <span>Mobile, web &amp; desktop</span><i>·</i>
      <span>Design systems</span><i>·</i>
      <span>Automation</span><i>·</i>
      <span>Launch execution</span>
    </div>
  </div>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Flagship work</p>
          <h2>One product.<br />The complete system.</h2>
        </div>
        <p>Continuum brings together product definition, local-first engineering, macOS and web experiences, brand, documentation, and a programmatic launch pipeline.</p>
      </div>

      <article class="continuum-feature">
        <div class="continuum-copy">
          <p class="eyebrow">{continuum.data.stage} · {continuum.data.year}</p>
          <h2>Think it through.<br />Watch the numbers move.</h2>
          <p>{continuum.data.summary}</p>
          <div class="continuum-scope">
            {continuum.data.capabilities.map((capability) => <span>{capability}</span>)}
          </div>
          <div class="button-row">
            <a class="button button--primary" href="/work/continuum/">Read the case study</a>
            <a class="button button--secondary" href={continuum.data.externalUrl} target="_blank" rel="noopener">View Continuum ↗</a>
          </div>
        </div>

        <div class="workspace-preview" aria-label="A simplified public preview of the Continuum calculation workspace">
          <div class="workspace-window">
            <div class="workspace-toolbar">
              <span><img src={continuum.data.image} alt="" width="24" height="24" />Continuum</span>
              <span>Monthly plan</span>
            </div>
            <div class="workspace-body">
              <div class="workspace-editor">
                <pre># A living monthly plan
income = 5200 in usd
rent = 1650 in usd
groceries = 620 in usd
flexible = 12% of income

<mark>remaining = income - rent -
groceries - flexible</mark></pre>
              </div>
              <div class="workspace-results">
                <small>Live results</small>
                <output>$5,200.00</output>
                <output>$1,650.00</output>
                <output>$620.00</output>
                <output><strong>$2,306.00</strong></output>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section" id="services">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">How I can help</p>
          <h2>Clarity first.<br />Then execution.</h2>
        </div>
        <p>Not a catalogue of disconnected skills. Three ways to reduce uncertainty and move a serious product forward.</p>
      </div>
      <div class="service-grid">
        {services.map((service, index) => <ServiceCard service={service} index={index} />)}
      </div>
      <div class="section-link-row">
        <a class="text-link" href="/services/">Explore how I can help <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2>Different surfaces.<br />The same ownership.</h2>
        </div>
        <p>Products across desktop, browser, mobile, and web—each shaped around a concrete problem rather than a fashionable stack.</p>
      </div>
      <div class="work-grid">
        {supportingWork.map((project) => <ProjectCard project={project} compact />)}
      </div>
    </div>
  </section>

  <section class="section method-section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">How I work</p>
          <h2>Reduce ambiguity.<br />Keep the signal.</h2>
        </div>
        <p>The path is rarely linear, but the priorities are: understand the real constraint, prove the critical path, and keep quality attached to the build.</p>
      </div>
      <div class="method-steps">
        <div class="method-step"><h3>Clarify the problem</h3><p>Separate the essential user outcome from the noise around the initial idea.</p></div>
        <div class="method-step"><h3>Prototype the critical path</h3><p>Test the hardest interaction or technical assumption before expanding the surface area.</p></div>
        <div class="method-step"><h3>Build the real system</h3><p>Move from proof to maintainable product architecture without losing the product intent.</p></div>
        <div class="method-step"><h3>Refine the experience</h3><p>Treat interaction, language, states, and visual polish as part of engineering quality.</p></div>
        <div class="method-step"><h3>Prepare it to ship</h3><p>Connect documentation, launch materials, repeatable assets, and honest product boundaries.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Ideas and field notes</p>
          <h2>I write to make the work legible.</h2>
        </div>
        <p>Notes from building products, choosing constraints, operating real systems, and learning what happens after something ships.</p>
      </div>
      <div class="writing-grid">
        {writing.map((article) => <WritingCard article={article} featured />)}
      </div>
      <div class="section-link-row"><a class="text-link" href="/writing/">Read all writing <span aria-hidden="true">→</span></a></div>
    </div>
  </section>

  <section class="section">
    <div class="shell about-strip">
      <div class="about-monogram" aria-hidden="true">SK</div>
      <div class="about-copy">
        <p class="eyebrow">A broader engineering practice</p>
        <h2>Android was the foundation—not the boundary.</h2>
        <p>Mobile engineering taught me to care about constraints, states, performance, and the last mile between code and a real person. Over time, that practice expanded into desktop and web products, product strategy, design systems, automation, and the work around a launch.</p>
        <a class="text-link" href="/about/">More about how I got here <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="closing-cta">
    <div class="shell closing-cta-grid">
      <div>
        <p class="eyebrow">Start with the real problem</p>
        <h2>Working through an ambitious product idea?</h2>
        <p>I’m open to thoughtful conversations about product direction, engineering, and the systems around shipping.</p>
      </div>
      <a class="button" href="/start/">Share what you’re building <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</BaseLayout>
