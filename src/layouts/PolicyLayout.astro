---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={`${frontmatter.title} for a product by Stoyan Korudzhiev.`}>
  <article class="prose-shell policy-shell">
    <a class="text-link" href="/">← Back to the main site</a>
    <header class="page-intro page-intro--compact">
      <p class="eyebrow">Policy</p>
      <h1>{frontmatter.title}</h1>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
